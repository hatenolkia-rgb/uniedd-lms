{
  "buildCommand": "CI=false react-scripts build && cp public/demo-booking.html build/demo-booking.html",
  "outputDirectory": "build",
  "installCommand": "npm install",
  "framework": "create-react-app",
  "routes": [
    {
      "src": "/book",
      "dest": "/demo-booking.html"
    },
    {
      "src": "/demo-booking.html",
      "dest": "/demo-booking.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
