{
  "buildCommand": "CI=false react-scripts build && cp public/demo-booking.html build/demo-booking.html",
  "outputDirectory": "build",
  "installCommand": "npm install",
  "framework": "create-react-app",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/book", "destination": "/demo-booking.html" },
    { "source": "/((?!demo-booking.html$).*)", "destination": "/index.html" }
  ]
}
